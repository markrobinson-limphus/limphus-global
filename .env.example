# Limphus Global — env for Next.js
# Copy to .env.local and fill in.

# Postgres (required for Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/limphus_global"

# Clerk (required for auth)
# Create app at https://dashboard.clerk.com
# Use exactly these variable names (Clerk looks for CLERK_SECRET_KEY):
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional: Stripe (for subscriptions later)
# STRIPE_SECRET_KEY="sk_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."

# Resend — send emails from the Closer (Approve & Send)
# Get key at https://resend.com/api-keys
RESEND_API_KEY="re_..."
# From address (must be verified in Resend). Example: "Limphus Global <noreply@limphus.ca>"
RESEND_FROM_EMAIL="Limphus Global <onboarding@resend.dev>"
